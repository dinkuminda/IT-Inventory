{
  "entities": {
    "Profile": {
      "title": "User Profile",
      "description": "Stores extended user details and roles.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The Firebase UID of the user." },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "department": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "employee"] },
        "needsPasswordChange": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "Asset": {
      "title": "Hardware Asset",
      "description": "Represents an IT asset like a laptop or server.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "serialNumber": { "type": "string" },
        "status": { "type": "string" },
        "assignedTo": { "type": "string", "description": "User email address." },
        "roles": { "type": "string" },
        "location": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "remark": { "type": "string" },
        "notes": { "type": "string" },
        "approvalStatus": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "License": {
      "title": "Software License",
      "description": "Track software licenses and usage.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "vendor": { "type": "string" },
        "key": { "type": "string" },
        "seats": { "type": "integer" },
        "usedSeats": { "type": "integer" },
        "expiryDate": { "type": "string", "format": "date" },
        "department": { "type": "string" },
        "notes": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    }
  },
  "firestore": {
    "/profiles/{userId}": {
      "schema": "Profile",
      "description": "Profiles of the administration users."
    },
    "/assets/{assetId}": {
      "schema": "Asset",
      "description": "Inventory of IT hardware assets."
    },
    "/licenses/{licenseId}": {
      "schema": "License",
      "description": "Inventory of software licenses."
    }
  }
}
